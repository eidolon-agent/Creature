# Environment Variables Configuration Template
# Copy this file to .env.local, .env.production, etc.

# ============ DATABASE ============
# PostgreSQL connection string (Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/creaturequest

# ============ NEYNAR SDK (Farcaster) ============
NEYNAR_API_KEY=your_neynar_api_key_here
FARCASTER_MINI_APP_URL=https://your-deployment.vercel.app

# ============ BLOCKCHAIN ============
# Base Sepolia (testnet) or Base Mainnet
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...

# Private key for deployment (NEVER commit to git!)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ============ CURRENCY PRICING ============
COINGECKO_API_KEY=your_coingecko_api_key (optional)

# ============ GAME CONFIGURATION ============
MAX_PLAYERS_PER_ZONE=100
COMBAT_TICK_RATE_MS=100
AI_THINK_INTERVAL_MS=500

# ============ SECURITY ============
# JWT secret for session management
NEXTAUTH_SECRET=your_secret_here
JWT_SECRET=your_jwt_secret_here

# ============ ANALYTICS ============
# Optional: Pinpoint, Amplitude, etc.
NEXT_PUBLIC_ANALYTICS_ID=

# ============ DEPLOYMENT ============
NEXT_PUBLIC_API_URL=https://api.creaturequest.io
VERCEL_PROTECTION_BYPASS=optional_for_ci_cd
