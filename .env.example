# Supabase PostgreSQL Database
# Use the pooler endpoint for production (recommended)
DATABASE_URL=postgresql://postgres.[project_ref].supabase.co:6543/postgres?sslmode=verify-full

# Alternatively, use direct endpoint (may require IPv6)
# DATABASE_URL=postgresql://postgres.[project_ref].supabase.co:5432/postgres?sslmode=verify-full

# Supabase Client (for Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://[project_ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key-from-supabase-dashboard]

# Neynar SDK - Required for Farcaster authentication
NEXT_PUBLIC_NEYNAR_API_KEY=[your-neynar-api-key-from-https://neynar.com]

# Smart Contract (Optional - for NFT features)
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddressHere

# Redis Cache (Optional - for real-time features)
REDIS_URL=redis://default:your-token@your-upstash-redis-url:6379

# App Configuration
NEXT_PUBLIC_APP_NAME=CreatureQuest
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
